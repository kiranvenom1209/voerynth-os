{
	"appId": "com.voerynth.os",
	"appName": "Voerynth OS",
	"webDir": "dist",
	"android": {
		"allowMixedContent": true,
		"backgroundColor": "#0f172a",
		"webContentsDebuggingEnabled": false
	},
	"plugins": {
		"ScreenBrightness": {
			"autoRestore": true
		},
		"KeepAwake": {},
		"SplashScreen": {
			"launchShowDuration": 0,
			"launchAutoHide": true,
			"backgroundColor": "#0f172a",
			"androidScaleType": "CENTER_CROP",
			"showSpinner": false
		},
		"Keyboard": {
			"resize": "native",
			"style": "dark",
			"resizeOnFullScreen": true
		}
	},
	"server": {
		"androidScheme": "https",
		"cleartext": true,
		"hostname": "localhost"
	}
}
